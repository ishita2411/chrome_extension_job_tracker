{
  "manifest_version": 3,
  "name": "Job Tracker Helper",
  "description": "A simple Chrome extension starter with a popup.",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://script.google.com/macros/d/*/usercallback",
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
